# Database Connection (Turso / libSQL)
# 開発環境 (SQLite): sqlite:///./sql_app.db
# 本番環境 (Turso)
DATABASE_URL=sqlite:///./sql_app.db
DATABASE_AUTH_TOKEN=

# FastAPI Security Settings
SECRET_KEY=
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# Google OAuth
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=
AUTH_SECRET=
REDIRECT_URI=http://localhost:8000/auth/google/callback

# External API Settings
EXTERNAL_API_URL=
